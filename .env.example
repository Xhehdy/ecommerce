# Copy this file to .env and fill in your values.
# These are passed to Flutter via --dart-define-from-file=.env

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key...
PAYSTACK_PUBLIC_KEY=pk_test_...your-paystack-public-key...
AUTH_REDIRECT_URL=http://localhost:3000/reset-password

# Used by dbmate-safe.sh for Postgres migrations.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require
